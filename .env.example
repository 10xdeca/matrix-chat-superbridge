MATRIX_SERVER_NAME=35-201-14-61.sslip.io
REGISTRATION_TOKEN=your-secure-registration-token

# ACME email for Let's Encrypt certificates (optional, but recommended)
ACME_EMAIL=admin@example.com

# Telegram bridge — get credentials from https://my.telegram.org
TELEGRAM_API_ID=your-telegram-api-id
TELEGRAM_API_HASH=your-telegram-api-hash

# Relay appservice — puppet-based relay bot that bridges megabridge portal rooms
# into the superbridge hub room with per-sender identity.
#
# Generate tokens:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Then paste relay/registration.yaml (with real values) in the admin room:
#   !admin appservices register
RELAY_AS_TOKEN=generate-with-secrets-token-hex-32
RELAY_HS_TOKEN=generate-with-secrets-token-hex-32
PORTAL_ROOMS=!whatsapp-portal-room-id:35-201-14-61.sslip.io=WhatsApp,!signal-portal-room-id:35-201-14-61.sslip.io=Signal
HUB_ROOM_ID=!superbridge-hub-room-id:35-201-14-61.sslip.io

# Double puppet mapping — maps bridge-logged-in Matrix users to their
# platform-specific puppet MXIDs so the relay bot uses the correct
# name and avatar per platform.  Format: user=puppet1,puppet2;user2=puppet3
# (localparts only — @prefix and :domain are added automatically)
#
# Find puppet IDs in the bridge DBs:
#   Signal:   SELECT mxid, signal_id FROM user_login;
#   WhatsApp: SELECT mxid, phone FROM user_login;
# Then construct: signal_<uuid> or whatsapp_<phone>
# RELAY_DOUBLE_PUPPETS=nick=signal_<uuid>,whatsapp_<phone>

# Relay log level — set to DEBUG for troubleshooting profile resolution
# RELAY_LOG_LEVEL=INFO

# Test override rooms — used by docker-compose.test.yml
# Create a test Signal group + test hub room, then fill these in.
# TEST_PORTAL_ROOMS=!test-signal-portal:35-201-14-61.sslip.io=Signal
# TEST_HUB_ROOM_ID=!test-hub-room:35-201-14-61.sslip.io
